   "source": [
    "## Calculate Max MIM Capacitor size"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "1f8a3a9a-692f-4929-8288-f53316be904a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "mim_cap_capacitance:2.3557248pF\n"
     ]
    }
   ],
   "source": [
    "#min_cap_w=350\n",
    "#mim_cap_l=50\n",
    "\n",
    "min_cap_w=34.32\n",
    "mim_cap_l=34.32\n",
    "mim_cap_area = min_cap_w * mim_cap_l\n",
    "mim_cap_capacitance = mim_cap_area * 2 /1000\n",
    "print(f\"mim_cap_capacitance:{mim_cap_capacitance}pF\")\n"
   ]
